# .env.example
# Copy this file to .env and fill in your actual values.
# IMPORTANT: .env must NEVER be committed to version control.
# Add .env to your .gitignore file.

# ─────────────────────────────────────────────
# Google Cloud Platform Configuration
# ─────────────────────────────────────────────

# Absolute path to your GCP Service Account JSON key file.
# The service account must have BigQuery Data Editor and BigQuery Job User roles.
# Example: C:\Users\YourName\credentials\financial-analytics-sa.json
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account-file.json

# Your GCP Project ID (found in the GCP Console).
GCP_PROJECT_ID=your-gcp-project-id

# The BigQuery Dataset ID where all Dimension and Fact tables will be created.
BQ_DATASET_ID=financial_dwh

# ─────────────────────────────────────────────
# Local Data Paths
# ─────────────────────────────────────────────

# Relative path to the directory containing the 7 raw Excel source files.
RAW_DATA_PATH=./data/raw/

# Relative path to the directory where cleaned/processed data will be saved.
PROCESSED_DATA_PATH=./data/processed/

# ─────────────────────────────────────────────
# Machine Learning Configuration
# ─────────────────────────────────────────────

# Path to save and load trained ML model artifacts.
MODEL_ARTIFACT_PATH=./reports/models/

# BigQuery table name for storing ML prediction outputs.
BQ_PREDICTIONS_TABLE=fact_model_predictions
